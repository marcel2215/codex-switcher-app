    "NSAppDataUsageDescription": {
      "comment": "Privacy - Other Application Data Usage Description",
      "extractionState": "extracted_with_value",
      "localizations": {
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتاج Codex Switcher إلى الوصول إلى بيانات التطبيق المشتركة الخاصة بالأدوات وأهداف التطبيق ومجلد Codex المرتبط الذي تختاره."
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher-এর উইজেট, অ্যাপ ইন্টেন্ট, এবং আপনার বেছে নেওয়া লিঙ্ক করা Codex ফোল্ডারের জন্য শেয়ার করা অ্যাপ ডেটাতে অ্যাক্সেস প্রয়োজন।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher necessita accedir a les dades de l'aplicació compartida per a widgets, App Intents i la carpeta Codex enllaçada que trieu."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher potřebuje přístup ke sdíleným datům aplikací pro widgety, objekty App Intent a propojenou složku Codex, kterou si vyberete."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher har brug for adgang til sine delte appdata for widgets, apphensigter og den linkede Codex-mappe, du vælger."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher benötigt Zugriff auf seine freigegebenen App-Daten für Widgets, App Intents und den verknüpften Codex-Ordner, den Sie auswählen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το Codex Switcher χρειάζεται πρόσβαση στα κοινόχρηστα δεδομένα εφαρμογής του για γραφικά στοιχεία, Προθέσεις εφαρμογής και τον συνδεδεμένο φάκελο Codex που επιλέγετε."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Codex Switcher needs access to its shared app data for widgets, App Intents, and the linked Codex folder you choose."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher needs access to its shared app data for widgets, App Intents, and the linked Codex folder you choose."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher needs access to its shared app data for widgets, App Intents, and the linked Codex folder you choose."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher needs access to its shared app data for widgets, App Intents, and the linked Codex folder you choose."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher needs access to its shared app data for widgets, App Intents, and the linked Codex folder you choose."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher necesita acceso a los datos de su aplicación compartida para widgets, App Intents y la carpeta vinculada Codex que elija."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher necesita acceso a los datos de su aplicación compartida para widgets, App Intents y la carpeta vinculada Codex que elija."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher tarvitsee pääsyn jaettuihin sovellustietoihinsa widgetejä, App Intents -sovelluksia ja valitsemaasi linkitettyä Codex-kansiota varten."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher a besoin d'accéder à ses données d'application partagées pour les widgets, les intentions d'application et le dossier Codex lié que vous choisissez."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher a besoin d'accéder à ses données d'application partagées pour les widgets, les intentions d'application et le dossier Codex lié que vous choisissez."
          }
        },
        "gu-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher ને વિજેટ્સ, એપ્લિકેશન ઇન્ટેન્ટ્સ અને તમે પસંદ કરેલ લિંક કરેલ Codex ફોલ્ડર માટે તેના શેર કરેલ એપ્લિકેશન ડેટાની ઍક્સેસની જરૂર છે."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher זקוק לגישה לנתוני האפליקציה המשותפים שלו עבור ווידג'טים, כוונות אפליקציה ולתיקיית Codex המקושרת שתבחר."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher को विजेट्स, ऐप इंटेंट्स और आपके द्वारा चुने गए लिंक किए गए Codex फ़ोल्डर के लिए अपने साझा ऐप डेटा तक पहुंच की आवश्यकता है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher treba pristup dijeljenim podacima aplikacije za widgete, namjere aplikacije i povezanu mapu Codex koju odaberete."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A Codex Switcher-nak hozzá kell férnie a megosztott alkalmazásadataihoz a modulok, az App Intents és az Ön által kiválasztott linkelt Codex mappához."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher memerlukan akses ke data aplikasi bersama untuk widget, Intent Aplikasi, dan folder Codex tertaut yang Anda pilih."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher deve accedere ai dati dell'app condivisa per widget, intenti dell'app e la cartella Codex collegata scelta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher は、ウィジェット、アプリ インテント、および選択したリンクされた Codex フォルダーの共有アプリ データにアクセスする必要があります。"
          }
        },
        "kn-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher ವಿಜೆಟ್‌ಗಳು, ಅಪ್ಲಿಕೇಶನ್ ಇಂಟೆಂಟ್‌ಗಳು ಮತ್ತು ನೀವು ಆಯ್ಕೆ ಮಾಡಿದ ಲಿಂಕ್ ಮಾಡಲಾದ Codex ಫೋಲ್ಡರ್‌ಗಾಗಿ ಹಂಚಿಕೊಂಡ ಅಪ್ಲಿಕೇಶನ್ ಡೇಟಾಗೆ ಪ್ರವೇಶದ ಅಗತ್ಯವಿದೆ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher은 위젯, 앱 인텐트 및 연결된 Codex 폴더에 대한 공유 앱 데이터에 액세스해야 합니다."
          }
        },
        "ml-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher എന്നതിന് വിജറ്റുകൾ, ആപ്പ് ഇൻഡൻ്റുകൾ, നിങ്ങൾ തിരഞ്ഞെടുക്കുന്ന ലിങ്ക് ചെയ്‌ത Codex ഫോൾഡർ എന്നിവയ്‌ക്കായി അതിൻ്റെ പങ്കിട്ട അപ്ലിക്കേഷൻ ഡാറ്റയിലേക്ക് ആക്‌സസ് ആവശ്യമാണ്."
          }
        },
        "mr-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher ला विजेट्स, ॲप इंटेंट्स आणि तुम्ही निवडलेल्या लिंक केलेल्या Codex फोल्डरसाठी सामायिक केलेल्या ॲप डेटामध्ये प्रवेश आवश्यक आहे."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher memerlukan akses kepada data apl kongsinya untuk widget, Niat Apl dan folder Codex terpaut yang anda pilih."
          }
        },
        "nl-NL": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher heeft toegang nodig tot de gedeelde app-gegevens voor widgets, app-intenties en de gekoppelde Codex-map die u kiest."
          }
        },
        "no": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher trenger tilgang til sine delte appdata for widgets, apphensikter og den tilknyttede Codex-mappen du velger."
          }
        },
        "or-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ୱିଜେଟ୍, ଆପ୍ ଇଣ୍ଟେଣ୍ଟସ୍ ଏବଂ ଲିଙ୍କ୍ ହୋଇଥିବା Codex ଫୋଲ୍ଡର୍ ପାଇଁ Codex Switcher ଏହାର ଅଂଶୀଦାର ଆପ୍ ତଥ୍ୟକୁ ପ୍ରବେଶ ଆବଶ୍ୟକ କରେ"
          }
        },
        "pa-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher ਨੂੰ ਵਿਜੇਟਸ, ਐਪ ਇੰਟੈਂਟਸ, ਅਤੇ ਤੁਹਾਡੇ ਦੁਆਰਾ ਚੁਣੇ ਗਏ ਲਿੰਕ ਕੀਤੇ Codex ਫੋਲਡਰ ਲਈ ਇਸਦੇ ਸਾਂਝੇ ਕੀਤੇ ਐਪ ਡੇਟਾ ਤੱਕ ਪਹੁੰਚ ਦੀ ਲੋੜ ਹੈ।"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher potrzebuje dostępu do udostępnionych danych aplikacji w zakresie widżetów, zamiarów aplikacji i wybranego połączonego folderu Codex."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher precisa de acesso aos dados de aplicativos compartilhados para widgets, App Intents e à pasta vinculada Codex que você escolher."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher necessita de acesso aos dados partilhados das aplicações para widgets, App Intents e à pasta ligada Codex que escolher."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher are nevoie de acces la datele aplicației partajate pentru widget-uri, App Intents și folderul Codex asociat pe care îl alegeți."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher требуется доступ к общим данным приложения для виджетов, намерений приложения и связанной папки Codex, которую вы выбираете."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher potrebuje prístup k údajom zdieľanej aplikácie pre miniaplikácie, zámery aplikácie a prepojený priečinok Codex, ktorý si vyberiete."
          }
        },
        "sl-SI": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher potrebuje dostop do svojih podatkov aplikacije v skupni rabi za pripomočke, namene aplikacije in povezano mapo Codex, ki jo izberete."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher behöver åtkomst till sina delade appdata för widgets, appavsikter och den länkade Codex-mappen du väljer."
          }
        },
        "ta-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcherக்கு விட்ஜெட்டுகள், ஆப் இன்டென்ட்கள் மற்றும் நீங்கள் தேர்வுசெய்த இணைக்கப்பட்ட Codex கோப்புறைக்கான பகிரப்பட்ட பயன்பாட்டுத் தரவுக்கான அணுகல் தேவை."
          }
        },
        "te-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcherకి మీరు ఎంచుకున్న విడ్జెట్‌లు, యాప్ ఇంటెంట్‌లు మరియు లింక్ చేయబడిన Codex ఫోల్డర్ కోసం దాని భాగస్వామ్య యాప్ డేటాకు యాక్సెస్ అవసరం."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher ต้องการเข้าถึงข้อมูลแอปที่แชร์สำหรับวิดเจ็ต App Intents และโฟลเดอร์ Codex ที่เชื่อมโยงที่คุณเลือก"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher'nin widget'lar, Uygulama Amaçları ve seçtiğiniz bağlantılı Codex klasörü için paylaşılan uygulama verilerine erişmesi gerekiyor."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher потребує доступу до спільних даних програми для віджетів, намірів програми та пов’язаної папки Codex, яку ви виберете."
          }
        },
        "ur-PK": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher کو ویجٹس، ایپ انٹینٹس، اور آپ کے منتخب کردہ لنک کردہ Codex فولڈر کے لیے اپنے مشترکہ ایپ ڈیٹا تک رسائی کی ضرورت ہے۔"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher cần quyền truy cập vào dữ liệu ứng dụng được chia sẻ cho các tiện ích, Ý định ứng dụng và thư mục Codex được liên kết mà bạn chọn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher 需要访问其共享的小部件应用程序数据、应用程序意图以及您选择的链接的 Codex 文件夹。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex Switcher 需要存取其共享的小部件應用程式資料、應用程式意圖以及您選擇的連結的 Codex 資料夾。"
          }
        }
      }
    },
