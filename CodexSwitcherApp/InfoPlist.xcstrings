    "NSAppDataUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar-SA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحتاج Codex Switcher إلى الوصول إلى بيانات التطبيق المشتركة الخاصة بالأدوات، وأهداف التطبيق، ومجلد Codex المرتبط الذي تختاره."
          }
        },
        "bn-BD" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher এর উইজেট, অ্যাপ ইন্টেন্ট এবং আপনার বেছে নেওয়া লিঙ্ক করা Codex ফোল্ডারের জন্য শেয়ার করা অ্যাপ ডেটাতে অ্যাক্সেস প্রয়োজন।"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher necessita accedir a les dades de l'aplicació compartida per a widgets, App Intents i la carpeta Codex enllaçada que trieu."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher potřebuje přístup ke sdíleným datům aplikací pro widgety, objekty App Intent a propojenou složku Codex, kterou si vyberete."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher har brug for adgang til sine delte appdata for widgets, apphensigter og den linkede Codex-mappe, du vælger."
          }
        },
        "de-DE" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher benötigt Zugriff auf seine freigegebenen App-Daten für Widgets, App Intents und den von Ihnen ausgewählten verknüpften Codex-Ordner."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher χρειάζεται πρόσβαση στα κοινόχρηστα δεδομένα της εφαρμογής του για γραφικά στοιχεία, Προθέσεις εφαρμογής και τον συνδεδεμένο φάκελο Codex που επιλέγετε."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher needs access to its shared app data for widgets, App Intents, and the linked Codex folder you choose."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher needs access to its shared app data for widgets, App Intents, and the linked Codex folder you choose."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher needs access to its shared app data for widgets, App Intents, and the linked Codex folder you choose."
          }
        },
        "en-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher needs access to its shared app data for widgets, App Intents, and the linked Codex folder you choose."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher necesita acceso a los datos de su aplicación compartida para widgets, App Intents y la carpeta Codex vinculada que elija."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher necesita acceso a los datos de su aplicación compartida para widgets, App Intents y la carpeta Codex vinculada que elija."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher tarvitsee pääsyn jaettuihin sovellustietoihinsa widgettejä, App Intents -sovelluksia ja valitsemaasi linkitettyä Codex-kansiota varten."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher a besoin d'accéder aux données de son application partagée pour les widgets, les intentions d'application et le dossier Codex lié que vous choisissez."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher a besoin d'accéder aux données de son application partagée pour les widgets, les intentions d'application et le dossier Codex lié que vous choisissez."
          }
        },
        "gu-IN" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher ને વિજેટ્સ, એપ્લિકેશન ઇન્ટેન્ટ્સ અને તમે પસંદ કરેલ લિંક કરેલ Codex ફોલ્ડર માટે તેના શેર કરેલ એપ્લિકેશન ડેટાની ઍક્સેસની જરૂર છે."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher זקוקה לגישה לנתוני האפליקציה המשותפים שלה עבור ווידג'טים, כוונות אפליקציה ולתיקיית Codex המקושרת שתבחר."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher को विजेट्स, ऐप इंटेंट्स और आपके द्वारा चुने गए लिंक किए गए Codex फ़ोल्डर के लिए अपने साझा ऐप डेटा तक पहुंच की आवश्यकता है।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher treba pristup dijeljenim podacima aplikacije za widgete, namjere aplikacije i povezanu mapu Codex koju odaberete."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher-nak hozzá kell férnie megosztott alkalmazásadataihoz a modulok, az App Intents és az Ön által kiválasztott összekapcsolt Codex mappához."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher memerlukan akses ke data aplikasi bersama untuk widget, Intent Aplikasi, dan folder Codex tertaut yang Anda pilih."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher deve accedere ai dati dell'app condivisa per widget, intenti dell'app e la cartella Codex collegata di tua scelta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher は、ウィジェット、アプリ インテント、および選択したリンクされた Codex フォルダーの共有アプリ データにアクセスする必要があります。"
          }
        },
        "kn-IN" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher ವಿಜೆಟ್‌ಗಳು, ಅಪ್ಲಿಕೇಶನ್ ಇಂಟೆಂಟ್‌ಗಳು ಮತ್ತು ನೀವು ಆಯ್ಕೆ ಮಾಡಿದ ಲಿಂಕ್ ಮಾಡಲಾದ Codex ಫೋಲ್ಡರ್‌ಗಾಗಿ ಹಂಚಿಕೊಂಡ ಅಪ್ಲಿಕೇಶನ್ ಡೇಟಾಗೆ ಪ್ರವೇಶದ ಅಗತ್ಯವಿದೆ."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher에는 위젯, 앱 인텐트 및 선택한 연결된 Codex 폴더에 대한 공유 앱 데이터에 대한 액세스 권한이 필요합니다."
          }
        },
        "ml-IN" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher എന്നതിന് വിജറ്റുകൾ, ആപ്പ് ഇൻഡൻ്റുകൾ, നിങ്ങൾ തിരഞ്ഞെടുക്കുന്ന ലിങ്ക് ചെയ്‌ത Codex ഫോൾഡർ എന്നിവയ്‌ക്കായി അതിൻ്റെ പങ്കിട്ട അപ്ലിക്കേഷൻ ഡാറ്റയിലേക്ക് ആക്‌സസ് ആവശ്യമാണ്."
          }
        },
        "mr-IN" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codex Switcher ला विजेट्स, ॲप इंटेंट्स आणि तुम्ही निवडलेल्या लिंक केलेल्या Codex फोल्डरसाठी शेअर केलेल्या ॲप डेटामध्ये प्रवेश आवश्यक आहे."
          }
        },
        "ms" : {
          "stringUnit" : {
